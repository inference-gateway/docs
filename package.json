{
  "name": "inference-gateway-docs",
  "version": "0.6.23",
  "private": true,
  "description": "Documentation site for Inference Gateway.",
  "type": "module",
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 vitepress dev",
    "build": "NODE_NO_WARNINGS=1 vitepress build",
    "preview": "NODE_NO_WARNINGS=1 vitepress preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore .vitepress",
    "lint:md:fix": "markdownlint \"**/*.md\" --ignore node_modules --ignore .vitepress --fix"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.34"
  }
}
